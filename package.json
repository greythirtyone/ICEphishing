{
  "name": "icephisher-app",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dev:web": "node server.js",
    "electron": "electron .",
    "dist:mac:x64": "electron-builder --mac dmg zip --x64 --publish never",
    "dist:mac:arm64": "electron-builder --mac dmg zip --arm64 --publish never",
    "dist:linux:x64": "electron-builder --linux AppImage tar.gz --x64 --publish never",
    "dist:win:x64": "electron-builder --win nsis zip --x64 --publish never"
  },
  "dependencies": {
    "express": "^4.21.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.icephisher.app",
    "productName": "ICEphisher",
    "asar": true,
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "server.js",
      "electron-main.js",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "linux": {
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    }
  }
}
